# 로컬 개발용: prisma/dev.db 사용 (이 파일을 .env로 복사 후 그대로 두면 됨)
DATABASE_URL="file:./dev.db"

# 프로덕션 (Vercel) 전용 — Turso 대시보드에서 발급받아 Vercel env에 설정
# TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
# TURSO_AUTH_TOKEN="<jwt-token>"

# 해시 솔트 (프로덕션에선 긴 랜덤 문자열로 교체)
BIRTH_SALT="change-me-in-production"
IP_SALT="change-me-in-production"
