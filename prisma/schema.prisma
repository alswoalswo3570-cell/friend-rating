generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FriendReview {
  id            String   @id @default(uuid())
  instaId       String
  birthCodeHash String
  scoreHumor    Int
  scoreLoyalty  Int
  scoreTexting  Int
  scoreVibes    Int
  scoreSecrets  Int
  comment       String
  ipHash        String
  createdAt     DateTime @default(now())

  @@index([instaId, birthCodeHash])
}
